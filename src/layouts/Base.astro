---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = 'Roastery Zen — 매일 아침의 한 문장.', bodyClass = '' } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta http-equiv="Cache-Control" content="no-store" />
    <link rel="icon" type="image/png" href="/roasteryzen_logo.png" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
